<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>追风的人 - 技术博客</title>
    <style>
        :root {
            --bg-start: #E8F1F8;
            --bg-end: #F5F9FC;
            --theme: #3478B5;
            --theme-light: #5A9BD4;
            --theme-soft: rgba(52, 120, 181, 0.08);
            --glass-bg: rgba(255, 255, 255, 0.50);
            --glass-bg-hover: rgba(255, 255, 255, 0.62);
            --glass-border: rgba(255, 255, 255, 0.55);
            --glass-highlight: rgba(255, 255, 255, 0.40);
            --shadow-sm: 0 2px 12px rgba(52, 120, 181, 0.06);
            --shadow-md: 0 4px 24px rgba(52, 120, 181, 0.08);
            --shadow-lg: 0 8px 36px rgba(52, 120, 181, 0.10);
            --text-primary: #1a2836;
            --text-secondary: #3d5468;
            --text-tertiary: #6b8299;
            --text-muted: #95aabb;
            --radius: 20px;
            --radius-sm: 14px;
            --transition: 0.2s cubic-bezier(0.33, 0.00, 0.20, 1.00);
            --font-stack: 'Noto Sans SC', '思源黑体', 'Source Han Sans SC', 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
            --max-width: 720px;
            --nav-height: 52px;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            font-size: 16px;
            -webkit-text-size-adjust: 100%;
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-stack);
            background: linear-gradient(170deg, var(--bg-start) 0%, var(--bg-end) 40%, #EDF4FA 70%, #E8F1F8 100%);
            background-attachment: fixed;
            min-height: 100vh;
            color: var(--text-primary);
            line-height: 1.7;
            letter-spacing: 0.01em;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 16px 16px 0;
            position: relative;
            overflow-x: hidden;
        }

        /* 背景装饰光斑 */
        body::before {
            content: '';
            position: fixed;
            top: -120px;
            right: -100px;
            width: 420px;
            height: 420px;
            background: radial-gradient(circle, rgba(180, 210, 235, 0.35) 0%, rgba(200, 220, 240, 0.08) 55%, transparent 75%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }
        body::after {
            content: '';
            position: fixed;
            bottom: -80px;
            left: -90px;
            width: 340px;
            height: 340px;
            background: radial-gradient(circle, rgba(170, 200, 225, 0.28) 0%, rgba(190, 215, 235, 0.06) 50%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }

        /* ============ 顶部导航 ============ */
        .top-nav {
            position: sticky;
            top: 12px;
            z-index: 100;
            width: 100%;
            max-width: var(--max-width);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 18px;
            background: var(--glass-bg);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius);
            border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            gap: 8px;
            flex-shrink: 0;
        }
        .top-nav:hover {
            background: var(--glass-bg-hover);
            box-shadow: var(--shadow-md);
        }
        .top-nav .brand {
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--theme);
            letter-spacing: 0.03em;
            white-space: nowrap;
            flex-shrink: 0;
            text-decoration: none;
            cursor: pointer;
            transition: var(--transition);
        }
        .top-nav .brand:hover {
            color: var(--theme-light);
        }
        .top-nav .nav-links {
            display: flex;
            gap: 6px;
            flex-shrink: 0;
            align-items: center;
        }
        .top-nav .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 0.875rem;
            font-weight: 500;
            padding: 7px 14px;
            border-radius: 24px;
            transition: var(--transition);
            cursor: pointer;
            white-space: nowrap;
            letter-spacing: 0.02em;
            position: relative;
        }
        .top-nav .nav-links a:hover {
            color: var(--theme);
            background: var(--theme-soft);
        }
        .top-nav .nav-links a.active {
            color: #fff;
            background: var(--theme);
            font-weight: 600;
            box-shadow: 0 2px 10px rgba(52, 120, 181, 0.25);
        }

        /* ============ 主容器 ============ */
        .main-container {
            width: 100%;
            max-width: var(--max-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 18px;
            padding: 18px 0 12px;
            position: relative;
            z-index: 1;
        }

        /* ============ 页面容器 ============ */
        .page {
            display: none;
            flex-direction: column;
            gap: 18px;
            animation: pageFadeIn 0.28s ease-out;
        }
        .page.active {
            display: flex;
        }
        @keyframes pageFadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ============ 液态玻璃卡片 ============ */
        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: var(--radius);
            border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
            padding: 22px 24px;
            position: relative;
            overflow: hidden;
            transition: var(--transition);
            cursor: default;
        }
        .glass-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 38%;
            background: linear-gradient(180deg, var(--glass-highlight) 0%, rgba(255, 255, 255, 0.05) 60%, rgba(255, 255, 255, 0) 100%);
            border-radius: var(--radius) var(--radius) 0 0;
            pointer-events: none;
            z-index: 2;
            transition: var(--transition);
        }
        .glass-card::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: var(--radius);
            pointer-events: none;
            z-index: 1;
            background: transparent;
            transition: var(--transition);
        }
        .glass-card>* {
            position: relative;
            z-index: 3;
        }

        /* hover: 轻微上浮+透光提亮 */
        .glass-card.card-hoverable:hover {
            background: var(--glass-bg-hover);
            box-shadow: var(--shadow-lg);
            transform: translateY(-3px);
            border-color: rgba(255, 255, 255, 0.7);
        }
        .glass-card.card-hoverable:hover::before {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.08) 50%, rgba(255, 255, 255, 0) 100%);
        }

        /* 点击缩放反馈 */
        .glass-card.card-clickable:active {
            transform: scale(0.975);
            transition: transform 0.1s ease-out;
        }
        .glass-card.card-clickable {
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }

        /* ============ 首页标题卡片 ============ */
        .hero-card {
            text-align: center;
            padding: 36px 24px 30px;
        }
        .hero-card .site-title {
            font-size: 2.4rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: 0.04em;
            margin-bottom: 8px;
            line-height: 1.3;
        }
        .hero-card .site-title .accent {
            color: var(--theme);
        }
        .hero-card .site-subtitle {
            font-size: 1rem;
            color: var(--text-tertiary);
            font-weight: 400;
            letter-spacing: 0.03em;
            line-height: 1.6;
            max-width: 480px;
            margin: 0 auto;
        }
        .hero-card .divider-dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--theme);
            margin: 14px auto 6px;
            opacity: 0.5;
        }

        /* ============ 首页特色小卡片网格 ============ */
        .feature-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }
        @media (max-width: 520px) {
            .feature-grid {
                grid-template-columns: 1fr;
                gap: 10px;
            }
        }
        .feature-mini-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: var(--radius);
            border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
            padding: 18px 16px;
            text-align: center;
            transition: var(--transition);
            cursor: pointer;
            position: relative;
            overflow: hidden;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }
        .feature-mini-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 35%;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 100%);
            border-radius: var(--radius) var(--radius) 0 0;
            pointer-events: none;
            z-index: 2;
            transition: var(--transition);
        }
        .feature-mini-card:hover {
            background: var(--glass-bg-hover);
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }
        .feature-mini-card:active {
            transform: scale(0.96);
            transition: transform 0.1s ease-out;
        }
        .feature-mini-card .feat-icon {
            font-size: 1.8rem;
            margin-bottom: 6px;
            position: relative;
            z-index: 3;
            display: block;
        }
        .feature-mini-card .feat-label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-secondary);
            position: relative;
            z-index: 3;
            letter-spacing: 0.02em;
        }
        .feature-mini-card .feat-desc {
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-top: 3px;
            position: relative;
            z-index: 3;
            letter-spacing: 0.02em;
        }

        /* ============ 文章列表条目 ============ */
        .article-list-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            background: var(--glass-bg);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius);
            border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }
        .article-list-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 36%;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.32) 0%, rgba(255, 255, 255, 0) 100%);
            border-radius: var(--radius) var(--radius) 0 0;
            pointer-events: none;
            z-index: 2;
            transition: var(--transition);
        }
        .article-list-item:hover {
            background: var(--glass-bg-hover);
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
            border-color: rgba(255, 255, 255, 0.7);
        }
        .article-list-item:active {
            transform: scale(0.975);
            transition: transform 0.1s ease-out;
        }
        .article-list-item .item-icon {
            flex-shrink: 0;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 3;
        }
        .article-list-item .item-icon svg {
            width: 28px;
            height: 28px;
            stroke: var(--theme);
            stroke-width: 1.6;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
        .article-list-item .item-info {
            flex: 1;
            min-width: 0;
            position: relative;
            z-index: 3;
        }
        .article-list-item .item-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-primary);
            letter-spacing: 0.02em;
            line-height: 1.4;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .article-list-item .item-meta {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 2px;
            letter-spacing: 0.02em;
        }
        .article-list-item .item-arrow {
            flex-shrink: 0;
            width: 20px;
            height: 20px;
            position: relative;
            z-index: 3;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
        }
        .article-list-item .item-arrow svg {
            width: 16px;
            height: 16px;
            stroke: var(--text-muted);
            stroke-width: 2;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
            transition: var(--transition);
        }
        .article-list-item:hover .item-arrow svg {
            stroke: var(--theme);
            transform: translateX(3px);
        }

        /* ============ 文章详情页 ============ */
        .article-detail-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2px;
        }
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 15px;
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 24px;
            border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text-secondary);
            transition: var(--transition);
            letter-spacing: 0.02em;
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }
        .back-btn:hover {
            background: var(--glass-bg-hover);
            color: var(--theme);
            box-shadow: var(--shadow-md);
        }
        .back-btn:active {
            transform: scale(0.95);
            transition: transform 0.1s ease-out;
        }
        .back-btn svg {
            width: 15px;
            height: 15px;
            stroke: currentColor;
            stroke-width: 2;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
        .article-detail-card .article-date {
            font-size: 0.8rem;
            color: var(--text-muted);
            letter-spacing: 0.03em;
            margin-bottom: 14px;
        }
        .article-detail-card .article-body {
            font-size: 0.92rem;
            color: var(--text-secondary);
            line-height: 1.85;
            letter-spacing: 0.02em;
        }
        .article-detail-card .article-body p {
            margin-bottom: 14px;
        }
        .article-detail-card .article-body p:last-child {
            margin-bottom: 0;
        }
        .article-detail-card .article-body h3 {
            font-size: 1.05rem;
            color: var(--text-primary);
            margin: 20px 0 8px;
            font-weight: 700;
            letter-spacing: 0.03em;
        }
        .article-detail-card .article-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 16px;
        }
        .article-detail-card .article-tags span {
            font-size: 0.73rem;
            padding: 5px 12px;
            border-radius: 20px;
            background: var(--theme-soft);
            color: var(--theme);
            font-weight: 500;
            letter-spacing: 0.02em;
            white-space: nowrap;
        }

        /* ============ 关于我页面 ============ */
        .about-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: linear-gradient(135deg, #dce9f5 0%, #c4d9ed 50%, #b8d0e8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 2rem;
            color: var(--theme);
            border: 3px solid rgba(255, 255, 255, 0.7);
            box-shadow: var(--shadow-sm);
            flex-shrink: 0;
            position: relative;
            z-index: 3;
        }
        .about-name {
            text-align: center;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: 0.03em;
        }
        .about-role {
            text-align: center;
            font-size: 0.85rem;
            color: var(--text-tertiary);
            letter-spacing: 0.03em;
            margin-bottom: 6px;
        }
        .about-bio {
            font-size: 0.9rem;
            color: var(--text-secondary);
            line-height: 1.8;
            letter-spacing: 0.02em;
            text-align: center;
            max-width: 500px;
            margin: 0 auto;
        }
        .skill-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-top: 10px;
        }
        .skill-tags span {
            font-size: 0.78rem;
            padding: 6px 14px;
            border-radius: 20px;
            background: var(--theme-soft);
            color: var(--theme);
            font-weight: 500;
            letter-spacing: 0.02em;
            white-space: nowrap;
        }

        /* ============ 底部通栏 ============ */
        .global-footer {
            width: 100%;
            max-width: var(--max-width);
            margin-top: 20px;
            margin-bottom: 16px;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: var(--radius);
            border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
            padding: 20px 20px 18px;
            text-align: center;
            position: relative;
            z-index: 10;
            flex-shrink: 0;
            overflow: hidden;
        }
        .global-footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 30%;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.28) 0%, rgba(255, 255, 255, 0) 100%);
            border-radius: var(--radius) var(--radius) 0 0;
            pointer-events: none;
            z-index: 2;
        }
        .global-footer>* {
            position: relative;
            z-index: 3;
        }
        .footer-nav {
            display: flex;
            justify-content: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }
        .footer-nav a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            letter-spacing: 0.02em;
            padding: 4px 8px;
            border-radius: 12px;
        }
        .footer-nav a:hover {
            color: var(--theme);
            background: var(--theme-soft);
        }
        .footer-info {
            font-size: 0.7rem;
            color: var(--text-muted);
            letter-spacing: 0.03em;
            line-height: 1.7;
        }
        .footer-info a {
            color: var(--text-tertiary);
            text-decoration: none;
            transition: var(--transition);
        }
        .footer-info a:hover {
            color: var(--theme);
        }

        /* ============ 响应式微调 ============ */
        @media (max-width: 520px) {
            body {
                padding: 10px 8px 0;
            }
            .top-nav {
                padding: 8px 12px;
                top: 6px;
                border-radius: 16px;
                gap: 4px;
            }
            .top-nav .brand {
                font-size: 0.9rem;
            }
            .top-nav .nav-links a {
                font-size: 0.75rem;
                padding: 6px 10px;
                border-radius: 20px;
            }
            .hero-card .site-title {
                font-size: 1.7rem;
            }
            .hero-card .site-subtitle {
                font-size: 0.85rem;
            }
            .glass-card {
                padding: 16px 14px;
                border-radius: 18px;
            }
            .glass-card::before {
                border-radius: 18px 18px 0 0;
            }
            .glass-card::after {
                border-radius: 18px;
            }
            .article-list-item {
                padding: 13px 14px;
                gap: 10px;
                border-radius: 18px;
            }
            .article-list-item::before {
                border-radius: 18px 18px 0 0;
            }
            .article-list-item .item-icon {
                width: 30px;
                height: 30px;
            }
            .article-list-item .item-icon svg {
                width: 22px;
                height: 22px;
            }
            .article-list-item .item-title {
                font-size: 0.85rem;
            }
            .feature-mini-card {
                padding: 14px 12px;
                border-radius: 18px;
            }
            .feature-mini-card::before {
                border-radius: 18px 18px 0 0;
            }
            .global-footer {
                border-radius: 18px;
                padding: 16px 14px 14px;
                margin-bottom: 10px;
            }
            .global-footer::before {
                border-radius: 18px 18px 0 0;
            }
            .main-container {
                gap: 12px;
                padding: 12px 0 6px;
            }
            .page {
                gap: 12px;
            }
            .feature-grid {
                gap: 10px;
            }
        }
        @media (min-width: 521px) and (max-width: 900px) {
            .hero-card .site-title {
                font-size: 2rem;
            }
            .glass-card {
                padding: 18px 20px;
            }
            .article-list-item {
                padding: 14px 16px;
            }
        }
    </style>
</head>
<body>

    <!-- ==================== 顶部导航 ==================== -->
    <nav class="top-nav" id="topNav">
        <span class="brand" onclick="navigateTo('home')" title="追风的人">追风的人</span>
        <div class="nav-links">
            <a onclick="navigateTo('home')" data-page="home" class="active" title="首页">首页</a>
            <a onclick="navigateTo('articles')" data-page="articles" title="文章">文章</a>
            <a onclick="navigateTo('about')" data-page="about" title="关于我">关于我</a>
        </div>
    </nav>

    <!-- ==================== 主容器 ==================== -->
    <div class="main-container" id="mainContainer">

        <!-- ========== 首页 ========== -->
        <section class="page active" id="page-home">
            <!-- 主标题卡片 -->
            <div class="glass-card hero-card card-hoverable">
                <h1 class="site-title">追<span class="accent">风</span>的人</h1>
                <div class="divider-dot"></div>
                <p class="site-subtitle">追逐技术之美，在代码中寻找自由。<br>用极简的方式，构建干净而有力的数字世界。</p>
            </div>

            <!-- 特色入口 -->
            <div class="feature-grid">
                <div class="feature-mini-card" onclick="navigateTo('articles')" title="浏览文章">
                    <span class="feat-icon">📝</span>
                    <span class="feat-label">技术随笔</span>
                    <span class="feat-desc">记录思考与实践</span>
                </div>
                <div class="feature-mini-card" onclick="navigateTo('about')" title="了解我">
                    <span class="feat-icon">🧑‍💻</span>
                    <span class="feat-label">关于我</span>
                    <span class="feat-desc">一个追风的技术人</span>
                </div>
            </div>

            <!-- 最新文章预览卡片 -->
            <div class="glass-card card-hoverable" style="text-align:center;">
                <p style="font-size:0.9rem;color:var(--text-tertiary);letter-spacing:0.03em;">最新文章</p>
                <p style="font-size:1rem;font-weight:600;color:var(--text-primary);margin-top:4px;letter-spacing:0.02em;cursor:pointer;" onclick="navigateTo('articles')" title="查看全部文章">在风中编码：我的极简开发环境 →</p>
            </div>
        </section>

        <!-- ========== 文章列表页 ========== -->
        <section class="page" id="page-articles">
            <div class="glass-card card-hoverable" style="text-align:center;">
                <h2 style="font-size:1.3rem;font-weight:700;color:var(--text-primary);letter-spacing:0.03em;">文章列表</h2>
                <p style="font-size:0.82rem;color:var(--text-tertiary);letter-spacing:0.03em;">技术随笔 · 思考记录</p>
            </div>
            <div id="articleListContainer">
                <!-- JS动态渲染 -->
            </div>
        </section>

        <!-- ========== 文章详情页 ========== -->
        <section class="page" id="page-article-detail">
            <div class="article-detail-header">
                <button class="back-btn" onclick="navigateTo('articles')" title="返回文章列表">
                    <svg viewBox="0 0 24 24"><polyline points="15 4 7 12 15 20"/></svg>
                    返回列表
                </button>
            </div>
            <div class="glass-card article-detail-card card-hoverable" id="articleDetailCard">
                <!-- JS动态渲染 -->
            </div>
        </section>

        <!-- ========== 关于我页面 ========== -->
        <section class="page" id="page-about">
            <div class="glass-card card-hoverable" style="text-align:center;">
                <div class="about-avatar">🌬️</div>
                <p class="about-name">追风的人</p>
                <p class="about-role">独立开发者 · 极简主义践行者</p>
                <div class="skill-tags">
                    <span>HTML/CSS</span><span>JavaScript</span><span>Python</span><span>Node.js</span><span>UI设计</span><span>开源热爱者</span>
                </div>
            </div>
            <div class="glass-card card-hoverable">
                <p class="about-bio">
                    你好，我是「追风的人」——一个在代码世界里不断前行的技术人。<br><br>
                    我相信好的技术应当是简洁而有力的。不追求花哨的堆砌，只专注于用最恰当的工具解决真正的问题。这个博客是我思考的延伸，记录着我在前端开发、工具链优化、以及技术美学上的探索。<br><br>
                    风无形，却有方向。我追的，是那份对技术的纯粹热爱与不断向前的勇气。
                </p>
            </div>
            <div class="glass-card card-hoverable" style="text-align:center;">
                <p style="font-size:0.85rem;color:var(--text-tertiary);letter-spacing:0.03em;">📬 想交流技术？欢迎邮件联系</p>
                <p style="font-size:0.9rem;font-weight:600;color:var(--theme);margin-top:4px;letter-spacing:0.02em;">zfengderen@gmail.com</p>
            </div>
        </section>
    </div>

    <!-- ==================== 底部通栏 ==================== -->
    <footer class="global-footer" id="globalFooter">
        <nav class="footer-nav">
            <a onclick="navigateTo('home')" title="首页">首页</a>
            <a onclick="navigateTo('articles')" title="文章">文章</a>
            <a onclick="navigateTo('about')" title="关于我">关于我</a>
        </nav>
        <div class="footer-info">
            第一行：@2026 追风的人 版权所有<br>
            第二行：联系邮箱 <a href="mailto:zfengderen@gmail.com">zfengderen@gmail.com</a>
        </div>
    </footer>

    <script>
        (function() {
            // ============ 文章数据 ============
            const articlesData = [{
                id: 1,
                iconType: 'code',
                title: '在风中编码：我的极简开发环境',
                date: '2026-05-20',
                tags: ['开发环境', '效率工具', '极简主义'],
                summary: '一套轻量级的开发环境配置，让编码回归纯粹。',
                body: `<p>在技术圈摸爬滚打多年后，我越发觉得：<strong>最好的开发环境，是那个让你忘记环境本身的环境。</strong></p>
<h3>编辑器：少即是多</h3>
<p>我选择的是最朴素的配置——一个轻量编辑器，加上寥寥几个必要插件。语法高亮、自动补全、Git集成，仅此而已。没有眼花缭乱的动画，没有占据半屏的侧边栏。写代码时，屏幕上的每一个像素都属于代码本身。</p>
<h3>终端：安静的力量</h3>
<p>一个配置良好的终端是开发者的第二个家。我用的是系统自带终端加上简单的别名配置。颜色方案选择低对比度的护眼主题，字体使用等宽无衬线字体。每次打开终端，就像进入了一个专注的空间。</p>
<h3>追风感悟</h3>
<p>工具永远服务于人，而非相反。当你的开发环境足够简单时，你会有更多精力去思考真正重要的事情——你要构建什么，以及为什么构建。</p>`
            }, {
                id: 2,
                iconType: 'design',
                title: '轻量级前端实践：不依赖框架的优雅',
                date: '2026-05-08',
                tags: ['前端', 'HTML/CSS', '架构思考'],
                summary: '回归HTML、CSS与原生JS，重新发现前端之美。',
                body: `<p>在这个前端框架层出不穷的时代，我想聊一个略显"叛逆"的话题：<strong>不用框架，我们能做到什么程度？</strong></p>
<h3>原生力量</h3>
<p>现代浏览器已经足够强大。CSS Grid和Flexbox让布局变得前所未有的简单；原生Fetch API让数据请求干净利落；Custom Elements让组件化成为可能。很多时候，我们引入框架只是出于习惯，而非必要。</p>
<h3>性能红利</h3>
<p>去掉框架意味着更小的打包体积、更快的首屏加载、更少的运行时开销。一个纯静态的HTML页面可以在瞬间完成渲染，这对用户来说是最直接的体验提升。</p>
<h3>追风感悟</h3>
<p>框架是工具，不是信仰。在选择技术栈时，先问自己：这个项目真的需要它吗？有时候，最简单的方案恰恰是最优雅的。</p>`
            }, {
                id: 3,
                iconType: 'note',
                title: '追风笔记：技术人的持续学习之道',
                date: '2026-04-15',
                tags: ['学习方法', '成长', '职业发展'],
                summary: '在信息洪流中保持清醒，建立自己的知识体系。',
                body: `<p>技术行业的变化速度令人眩晕。每天都有新框架、新工具、新概念涌现。<strong>如何在这样的环境中保持学习效率，同时不迷失方向？</strong></p>
<h3>建立知识锚点</h3>
<p>我习惯将知识分为三层：底层原理（如网络协议、数据结构）、中层技能（如设计模式、架构思维）、上层工具（如具体框架、库）。底层原理变化最慢，投资回报率最高；上层工具更新最快，按需学习即可。</p>
<h3>输出是最好的输入</h3>
<p>这个博客存在的意义之一，就是强迫自己把模糊的理解转化为清晰的文字。每次写作都是一次深度思考的过程，让我发现自己知识体系中的漏洞。</p>
<h3>追风感悟</h3>
<p>学习不是为了追赶每一个潮流，而是为了建立自己的判断力。知道什么值得学，什么可以暂时放下，这本身就是一种重要的能力。</p>`
            }, {
                id: 4,
                iconType: 'tool',
                title: '静谧之力：CSS现代布局的简约美学',
                date: '2026-03-28',
                tags: ['CSS', '布局', '设计美学'],
                summary: '用CSS Grid和Flexbox构建干净、响应式的页面结构。',
                body: `<p>CSS布局的演进是前端领域最被低估的变革之一。<strong>从浮动到Flexbox再到Grid，我们拥有了前所未有的布局能力。</strong></p>
<h3>Grid的魔力</h3>
<p>CSS Grid让我能够用声明式的方式描述二维布局。几行代码就能实现以前需要大量嵌套和计算才能完成的效果。而且它天然响应式——结合minmax()和auto-fill，布局可以优雅地适应不同屏幕尺寸。</p>
<h3>简约即美</h3>
<p>好的布局应当是"隐形"的。用户不会注意到你的Grid设置了几个轨道，但他们能感受到页面是否舒适、信息是否清晰。这种无形的优雅，正是CSS布局的魅力所在。</p>
<h3>追风感悟</h3>
<p>技术的美往往藏在细节里。一个间距恰到好处的页面，比任何炫酷的动画都更能打动人心。</p>`
            }];

            // ============ 图标SVG生成函数 ============
            function getItemIconSVG(iconType) {
                const icons = {
                    code: '<svg viewBox="0 0 24 24"><polyline points="8 6 2 12 8 18"/><polyline points="16 6 22 12 16 18"/><line x1="13" y1="4" x2="11" y2="20"/></svg>',
                    design: '<svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="2"/><path d="M21 15l-5-5L5 21"/></svg>',
                    note: '<svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
                    tool: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/></svg>',
                    default: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>'
                };
                return icons[iconType] || icons['default'];
            }

            function getArrowSVG() {
                return '<svg viewBox="0 0 24 24"><polyline points="8 4 16 12 8 20"/></svg>';
            }

            // ============ 渲染文章列表 ============
            function renderArticleList() {
                const container = document.getElementById('articleListContainer');
                let html = '';
                articlesData.forEach(article => {
                    html += `
                <div class="article-list-item" onclick="openArticleDetail(${article.id})" title="${article.title}">
                  <div class="item-icon">${getItemIconSVG(article.iconType)}</div>
                  <div class="item-info">
                    <div class="item-title">${article.title}</div>
                    <div class="item-meta">${article.date}</div>
                  </div>
                  <div class="item-arrow">${getArrowSVG()}</div>
                </div>`;
                });
                container.innerHTML = html;
            }

            // ============ 打开文章详情 ============
            window.openArticleDetail = function(articleId) {
                const article = articlesData.find(a => a.id === articleId);
                if (!article) return;
                const detailCard = document.getElementById('articleDetailCard');
                let tagsHTML = '';
                article.tags.forEach(tag => {
                    tagsHTML += `<span>${tag}</span>`;
                });
                detailCard.innerHTML = `
              <h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary);letter-spacing:0.03em;margin-bottom:4px;line-height:1.4;">${article.title}</h2>
              <div class="article-date">${article.date}</div>
              <div class="article-body">${article.body}</div>
              <div class="article-tags">${tagsHTML}</div>`;
                navigateTo('article-detail', false);
                // 滚动到顶部
                window.scrollTo({ top: 0, behavior: 'smooth' });
            };

            // ============ 页面导航 ============
            function navigateTo(pageName, scrollTop = true) {
                // 隐藏所有页面
                const pages = document.querySelectorAll('.page');
                pages.forEach(p => p.classList.remove('active'));

                // 显示目标页面
                const targetPage = document.getElementById('page-' + pageName);
                if (targetPage) {
                    targetPage.classList.add('active');
                }

                // 更新顶部导航active状态
                const navLinks = document.querySelectorAll('.top-nav .nav-links a');
                navLinks.forEach(link => {
                    link.classList.remove('active');
                    const linkPage = link.getAttribute('data-page');
                    if (linkPage === pageName || (pageName === 'article-detail' && linkPage === 'articles')) {
                        link.classList.add('active');
                    }
                });

                // 滚动到顶部
                if (scrollTop) {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }

                // 更新URL hash
                if (pageName === 'article-detail') {
                    window.location.hash = 'article';
                } else {
                    window.location.hash = pageName;
                }
            }

            // 暴露到全局
            window.navigateTo = navigateTo;

            // ============ 初始化 ============
            function init() {
                renderArticleList();

                // 根据URL hash初始化页面
                const hash = window.location.hash.replace('#', '');
                if (hash === 'articles' || hash === 'article') {
                    navigateTo('articles', false);
                } else if (hash === 'about') {
                    navigateTo('about', false);
                } else if (hash === 'article') {
                    navigateTo('articles', false);
                } else {
                    navigateTo('home', false);
                }

                // 监听hash变化
                window.addEventListener('hashchange', function() {
                    const h = window.location.hash.replace('#', '');
                    if (h === 'articles' || h === 'article') {
                        navigateTo('articles', true);
                    } else if (h === 'about') {
                        navigateTo('about', true);
                    } else if (h === 'home') {
                        navigateTo('home', true);
                    }
                });
            }

            // DOM加载完成后初始化
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
        })();
    </script>
</body>
</html>